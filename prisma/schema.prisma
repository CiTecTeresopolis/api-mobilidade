generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id     String @id @default(uuid())
  name   String
  email String
  data     DateTime
  cpf      String
  rua String
  cep String
  bairro String
  cidade String
  estado String
 
}